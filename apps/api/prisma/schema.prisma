generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model University {
  id                    String                 @id @default(uuid())
  name                  String
  shortName             String                 @unique
  location              String?
  email                 String?
  estYear               Int?
  website               String?
  adminUserId           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  books                 Book[]
  companies             Company[]
  feeStructures         FeeStructure[]
  publicPortalConfig    PublicPortalConfig?
  verificationRequests  VerificationRequest[]
  admissionApplications AdmissionApplication[]
  batches               Batch[]
  assets                CampusAsset[]
  complaints            Complaint[]
  courses               Course[]
  departments           Department[]
  emergencyAlerts       EmergencyAlert[]
  events                Event[]
  faculty               Faculty[]
  inventory             InventoryItem[]
  patrolRoutes          PatrolRoute[]
  procurements          ProcurementRequest[]
  programs              Program[]
  resources             Resource[]
  scholarships          Scholarship[]
  incidents             SecurityIncident[]
  students              Student[]
  timetables            Timetable[]
  users                 User[]
  vendors               Vendor[]
  visitorLogs           VisitorLog[]

  @@map("universities")
}

model Department {
  id                    String                 @id @default(uuid())
  universityId          String
  name                  String
  shortName             String
  hod                   String?
  email                 String?
  adminUserId           String?
  createdAt             DateTime               @default(now())
  books                 Book[]
  admissionApplications AdmissionApplication[]
  admissionInquiries    AdmissionInquiry[]
  batches               Batch[]
  auditLogs             BudgetAuditLog[]
  complianceAudits      ComplianceAudit[]
  courses               Course[]
  budgets               DepartmentBudget[]
  university            University             @relation(fields: [universityId], references: [id], onDelete: Cascade)
  electiveBaskets       ElectiveBasket[]
  faculty               FacultyDepartment[]
  programs              Program[]
  sessionTypes          SessionType[]
  students              Student[]
  studyGroups           StudyGroup[]
  timeBlocks            TimeBlock[]
  timetables            Timetable[]

  @@index([universityId])
  @@map("departments")
}

model FacultyDepartment {
  facultyId    String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  faculty      Faculty    @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@id([facultyId, departmentId])
  @@map("faculty_departments")
}

model Faculty {
  id               String                @id @default(uuid())
  universityId     String
  name             String
  email            String                @unique
  phone            String?
  designation      String?
  qualifications   String?
  experience       String?
  userId           String?
  availability     Json?
  createdAt        DateTime              @default(now())
  payrollConfigId  String?               @unique
  salarySlips      SalarySlip[]
  assignments      Assignment[]
  classes          Class[]
  taughtDivisions  Division[]            @relation("DivisionTeacher")
  faculty1Pairs    ElectiveFacultyPair[] @relation("Faculty1Pairs")
  faculty2Pairs    ElectiveFacultyPair[] @relation("Faculty2Pairs")
  electiveOptions  ElectiveOption[]
  payrollConfig    PayrollConfig?        @relation(fields: [payrollConfigId], references: [id])
  university       University            @relation(fields: [universityId], references: [id], onDelete: Cascade)
  user             User?                 @relation(fields: [userId], references: [id])
  audits           FacultyAudit[]
  departments      FacultyDepartment[]
  feedback         FacultyFeedback[]
  subjects         FacultySubject[]
  publications     Publication[]
  quizzes          Quiz[]
  grants           ResearchGrant[]
  reviews          ResearchReview[]      @relation("FacultyReviews")
  studyMaterials   StudyMaterial[]
  timetableChanges TimetableChange[]
  faculty2Slots    TimetableSlot[]       @relation("Faculty2Slots")
  timetableSlots   TimetableSlot[]

  @@index([universityId])
  @@map("faculties")
}

model FacultyFeedback {
  id           String   @id @default(uuid())
  facultyId    String
  studentId    String
  rating       Int
  comment      String?
  semester     Int
  academicYear String
  createdAt    DateTime @default(now())
  faculty      Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([facultyId, studentId, semester, academicYear])
  @@map("faculty_feedback")
}

model FacultySubject {
  id               String  @id @default(uuid())
  facultyId        String
  courseId         String
  isPrimary        Boolean @default(true)
  proficiencyLevel Int     @default(5)
  course           Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  faculty          Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@unique([facultyId, courseId])
  @@map("faculty_subjects")
}

model Publication {
  id              String   @id @default(uuid())
  facultyId       String
  title           String
  abstract        String?
  journal         String?
  doi             String?  @unique
  publicationDate DateTime
  citationsCount  Int      @default(0)
  impactFactor    Float?
  url             String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  faculty         Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@index([facultyId])
  @@map("publications")
}

model ResearchGrant {
  id               String             @id @default(uuid())
  facultyId        String
  title            String
  agency           String
  amount           Float
  status           String             @default("PROPOSAL_DRAFT")
  description      String?
  proposalBody     String?
  budgetBreakdown  Json?
  reviewComments   Json?
  startDate        DateTime
  endDate          DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  ethicalClearance EthicalClearance?
  expenditures     GrantExpenditure[]
  faculty          Faculty            @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  reviews          ResearchReview[]
  resourceBookings ResourceBooking[]

  @@index([facultyId])
  @@map("research_grants")
}

model ResearchReview {
  id             String        @id @default(uuid())
  grantId        String
  reviewerId     String
  score          Int           @default(0)
  recommendation String?
  rubric         Json?
  comments       String?
  status         String        @default("PENDING")
  isAnonymous    Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  grant          ResearchGrant @relation(fields: [grantId], references: [id], onDelete: Cascade)
  reviewer       Faculty       @relation("FacultyReviews", fields: [reviewerId], references: [id])

  @@index([grantId])
  @@index([reviewerId])
  @@map("research_reviews")
}

model GrantExpenditure {
  id          String        @id @default(uuid())
  grantId     String
  amount      Float
  description String
  category    String
  date        DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  grant       ResearchGrant @relation(fields: [grantId], references: [id], onDelete: Cascade)

  @@index([grantId])
  @@map("grant_expenditures")
}

model EthicalClearance {
  id             String        @id @default(uuid())
  grantId        String        @unique
  status         String        @default("PENDING")
  submissionDate DateTime      @default(now())
  approvalDate   DateTime?
  reviewerNotes  String?
  riskScore      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  grant          ResearchGrant @relation(fields: [grantId], references: [id], onDelete: Cascade)

  @@map("ethical_clearances")
}

model FacultyAudit {
  id              String   @id @default(uuid())
  facultyId       String
  auditorId       String?
  academicYear    String
  semester        Int
  overallScore    Float
  researchImpact  Float
  teachingScore   Float
  aiSummary       String
  recommendations String
  status          String   @default("DRAFT")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  faculty         Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@index([facultyId])
  @@map("faculty_audits")
}

model CurriculumAudit {
  id             String   @id @default(uuid())
  courseId       String
  academicYear   String
  alignmentScore Float
  gapAnalysis    String
  identifiedGaps Json?
  suggestions    String
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("curriculum_audits")
}

model Course {
  id               String            @id @default(uuid())
  departmentId     String?
  universityId     String
  name             String
  code             String
  program          String?
  credits          Int               @default(4)
  weeklyHrs        Int               @default(4)
  semester         Int?
  type             String            @default("Theory")
  createdAt        DateTime          @default(now())
  isElective       Boolean           @default(false)
  labDuration      Int               @default(60)
  requiredRoomType String?
  sessionTypeId    String?
  assignments      Assignment[]
  classes          Class[]
  department       Department?       @relation(fields: [departmentId], references: [id])
  sessionType      SessionType?      @relation("CourseToSessionType", fields: [sessionTypeId], references: [id])
  university       University        @relation(fields: [universityId], references: [id], onDelete: Cascade)
  curriculumAudits CurriculumAudit[]
  electiveOptions  ElectiveOption[]
  facultySubjects  FacultySubject[]
  quizzes          Quiz[]
  studyMaterials   StudyMaterial[]
  subjectResults   SubjectResult[]
  timetableSlots   TimetableSlot[]

  @@index([universityId, departmentId])
  @@map("courses")
}

model Batch {
  id             String          @id @default(uuid())
  departmentId   String?
  universityId   String
  name           String
  program        String?
  semester       Int?
  year           String?
  createdAt      DateTime        @default(now())
  assignments    Assignment[]
  department     Department?     @relation(fields: [departmentId], references: [id])
  university     University      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  divisions      Division[]
  students       Student[]
  studyMaterials StudyMaterial[]
  timetableSlots TimetableSlot[]
  timetables     Timetable[]

  @@index([universityId, departmentId])
  @@map("batches")
}

model Resource {
  id               String            @id @default(uuid())
  universityId     String
  name             String
  type             String
  capacity         Int               @default(30)
  floor            String?
  building         String?
  createdAt        DateTime          @default(now())
  status           String            @default("AVAILABLE")
  isResearchOnly   Boolean           @default(false)
  specifications   Json?             @default("{}")
  requiresApproval Boolean           @default(false)
  primaryDivisions Division[]
  bookings         ResourceBooking[]
  university       University        @relation(fields: [universityId], references: [id], onDelete: Cascade)
  timetableChanges TimetableChange[]
  timetableSlots   TimetableSlot[]

  @@map("resources")
}

model Program {
  id                    String                 @id @default(uuid())
  universityId          String
  name                  String
  shortName             String
  type                  String
  duration              Int                    @default(2)
  totalSems             Int                    @default(4)
  departmentId          String?
  feeStructures         FeeStructure[]
  admissionApplications AdmissionApplication[]
  department            Department?            @relation(fields: [departmentId], references: [id])
  university            University             @relation(fields: [universityId], references: [id], onDelete: Cascade)
  results               Result[]
  students              Student[]

  @@map("programs")
}

model TimeBlock {
  id             String          @id @default(uuid())
  departmentId   String
  name           String
  startTime      String
  endTime        String
  duration       Int
  isBreak        Boolean         @default(false)
  createdAt      DateTime        @default(now())
  slotNumber     Int             @default(1)
  department     Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  timetableSlots TimetableSlot[]

  @@map("time_blocks")
}

model SessionType {
  id               String          @id @default(uuid())
  departmentId     String
  name             String
  durationRule     Int             @default(60)
  roomTypeRequired String?
  createdAt        DateTime        @default(now())
  courses          Course[]        @relation("CourseToSessionType")
  department       Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  timetableSlots   TimetableSlot[]

  @@map("session_types")
}

model ElectiveBasket {
  id              String                   @id @default(uuid())
  departmentId    String
  subjectCode     String
  name            String
  semester        Int?
  program         String?
  weeklyHrs       Int                      @default(2)
  createdAt       DateTime                 @default(now())
  department      Department               @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  facultyPairs    ElectiveFacultyPair[]
  options         ElectiveOption[]
  studentMappings StudentElectiveMapping[]

  @@map("elective_baskets")
}

model ElectiveFacultyPair {
  id         String         @id @default(uuid())
  basketId   String
  faculty1Id String
  faculty2Id String
  dayOfWeek  Int
  createdAt  DateTime       @default(now())
  basket     ElectiveBasket @relation(fields: [basketId], references: [id], onDelete: Cascade)
  faculty1   Faculty        @relation("Faculty1Pairs", fields: [faculty1Id], references: [id])
  faculty2   Faculty        @relation("Faculty2Pairs", fields: [faculty2Id], references: [id])

  @@map("elective_faculty_pairs")
}

model ElectiveOption {
  id              String                   @id @default(uuid())
  basketId        String
  courseId        String
  facultyId       String?
  enrollmentCount Int                      @default(30)
  createdAt       DateTime                 @default(now())
  basket          ElectiveBasket           @relation(fields: [basketId], references: [id], onDelete: Cascade)
  course          Course                   @relation(fields: [courseId], references: [id])
  faculty         Faculty?                 @relation(fields: [facultyId], references: [id])
  subgroups       ElectiveSubgroup[]
  studentMappings StudentElectiveMapping[]

  @@map("elective_options")
}

model ElectiveSubgroup {
  id              String         @id @default(uuid())
  optionId        String
  subgroupId      String
  enrollmentCount Int            @default(30)
  createdAt       DateTime       @default(now())
  option          ElectiveOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@map("elective_subgroups")
}

model Timetable {
  id            String          @id @default(uuid())
  universityId  String
  departmentId  String?
  batchId       String?
  name          String?
  isSpecial     Boolean         @default(false)
  status        String          @default("ACTIVE")
  configJson    Json?
  generatedBy   String          @default("AI")
  version       Int             @default(1)
  conflictCount Int             @default(0)
  generationMs  Int?
  createdAt     DateTime        @default(now())
  divisionId    String?
  slots         TimetableSlot[]
  batch         Batch?          @relation(fields: [batchId], references: [id])
  department    Department?     @relation(fields: [departmentId], references: [id])
  division      Division?       @relation(fields: [divisionId], references: [id])
  university    University      @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@map("timetables")
}

model TimetableSlot {
  id                 String              @id @default(uuid())
  timetableId        String
  dayOfWeek          Int
  slotNumber         Int
  startTime          String
  endTime            String
  courseId           String?
  facultyId          String?
  roomId             String?
  batchId            String?
  isBreak            Boolean             @default(false)
  slotType           String              @default("THEORY")
  basketId           String?
  isElective         Boolean             @default(false)
  optionId           String?
  blockId            String?
  faculty2Id         String?
  sessionTypeId      String?
  classId            String?
  divisionId         String
  attendanceSessions AttendanceSession[]
  timetableChanges   TimetableChange[]
  batch              Batch?              @relation(fields: [batchId], references: [id])
  block              TimeBlock?          @relation(fields: [blockId], references: [id])
  class              Class?              @relation(fields: [classId], references: [id])
  course             Course?             @relation(fields: [courseId], references: [id])
  division           Division            @relation(fields: [divisionId], references: [id])
  faculty2           Faculty?            @relation("Faculty2Slots", fields: [faculty2Id], references: [id])
  faculty            Faculty?            @relation(fields: [facultyId], references: [id])
  room               Resource?           @relation(fields: [roomId], references: [id])
  sessionType        SessionType?        @relation(fields: [sessionTypeId], references: [id])
  timetable          Timetable           @relation(fields: [timetableId], references: [id], onDelete: Cascade)

  @@map("timetable_slots")
}

model User {
  id                      String                   @id @default(uuid())
  username                String                   @unique
  email                   String?                  @unique
  passwordHash            String?
  firebaseUid             String?                  @unique
  role                    String
  entityId                String?
  universityId            String?
  phoneNumber             String?
  address                 String?
  isActive                Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  lastLogin               DateTime?
  fcmToken                String?
  failedLoginAttempts     Int                      @default(0)
  lockedUntil             DateTime?
  passwordChangedAt       DateTime                 @default(now())
  sessionVersion          Int                      @default(0)
  lastActivityAt          DateTime?
  reviewerApplications    AdmissionApplication[]   @relation("ReviewerApplications")
  assignedInquiries       AdmissionInquiry[]       @relation("AssignedInquiries")
  logs                    AuditLog[]
  receivedConnectRequests ConnectRequest[]         @relation("Receiver")
  sentConnectRequests     ConnectRequest[]         @relation("Sender")
  faculty                 Faculty[]
  assignedMaintenance     MaintenanceTicket[]      @relation("AssignedMaintenance")
  messageHistory          MessageHistory[]
  syncLogs                MessageSyncLog[]
  messages                Message[]
  notificationLogs        NotificationLog[]
  notificationPreferences NotificationPreference[]
  notifications           Notification[]
  patrolAssignments       PatrolRoute[]            @relation("PatrolOfficer")
  permissions             Permission[]
  procurementsApproved    ProcurementRequest[]     @relation("ApprovedBy")
  procurementsRequested   ProcurementRequest[]     @relation("RequestedBy")
  resourceBookings        ResourceBooking[]
  assignedIncidents       SecurityIncident[]       @relation("AssignedTo")
  reportedIncidents       SecurityIncident[]       @relation("ReportedBy")
  stockActions            StockLog[]               @relation("PerformedBy")
  performedTransfers      StudentTransferLog[]     @relation("PerformedTransfers")
  student                 Student?
  addedSubscribers        Subscriber[]             @relation("UserSubscribers")
  subscription            SubscriptionControl?
  sessions                UserSession[]
  university              University?              @relation(fields: [universityId], references: [id], onDelete: Cascade)
  visitorHosts            VisitorLog[]             @relation("Host")
  threads                 ChatThread[]             @relation("ThreadParticipants")

  @@map("users")
}

model AuditLog {
  id              String   @id @default(uuid())
  userId          String?
  action          String
  entityType      String?
  entityId        String?
  changes         Json?
  status          String   @default("SUCCESS")
  endpoint        String?
  method          String?
  durationMs      Int?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())
  blockNumber     Int?
  isVerified      Boolean  @default(false)
  transactionHash String?
  user            User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model GlobalSettings {
  id                     String   @id @default("system-config")
  platformName           String   @default("SmartCampus OS")
  supportEmail           String   @default("support@smartcampus.ac.in")
  maintenanceMode        Boolean  @default(false)
  sessionTimeout         Int      @default(10)
  mfaEnabled             Boolean  @default(false)
  logRetention           String   @default("30")
  autoBackups            Boolean  @default(false)
  updatedAt              DateTime @updatedAt
  loginAttemptLimit      Int      @default(5)
  lockoutDurationMinutes Int      @default(15)
  sessionWarningMinutes  Int      @default(2)

  @@map("global_settings")
}

model UserSession {
  id                String    @id @default(uuid())
  userId            String
  sessionToken      String    @unique
  csrfToken         String
  createdAt         DateTime  @default(now())
  expiresAt         DateTime
  lastActivityAt    DateTime  @default(now())
  invalidatedAt     DateTime?
  invalidatedReason String?
  ipAddress         String?
  userAgent         String?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model Inquiry {
  id            String   @id @default(uuid())
  name          String?
  email         String
  contactNumber String?
  organization  String?
  message       String?
  status        String   @default("NEW")
  ipAddress     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  source        String?  @default("get_started_popup")

  @@map("inquiries")
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  status    String   @default("ACTIVE")
  creatorId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creator   User?    @relation("UserSubscribers", fields: [creatorId], references: [id])

  @@map("subscribers")
}

model Permission {
  id           String   @id @default(uuid())
  roleId       String
  userId       String?
  module       String
  action       String
  allowed      Boolean  @default(false)
  restrictions Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action])
  @@map("permissions")
}

model SubscriptionControl {
  id                 String    @id @default(uuid())
  userId             String    @unique
  canSubscribe       Boolean   @default(true)
  subscriptionLimit  Int       @default(100)
  subscriptionExpiry DateTime?
  autoRenew          Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscription_controls")
}

model PublicPortalConfig {
  id           String     @id @default(uuid())
  universityId String     @unique
  slug         String     @unique
  customDomain String?
  branding     Json
  features     Json
  rateLimits   Json
  updatedAt    DateTime   @updatedAt
  university   University @relation(fields: [universityId], references: [id])
}

model Student {
  id                  String                      @id @default(uuid())
  universityId        String
  departmentId        String
  enrollmentNo        String                      @unique
  name                String
  email               String                      @unique
  phone               String?
  batchId             String
  programId           String
  admissionYear       Int
  photoUrl            String?
  userId              String?                     @unique
  currentCompany      String?
  currentRole         String?
  industryExperience  Json?
  isAlumnus           Boolean                     @default(false)
  skills              Json?
  bookLoans           BookLoan[]
  feePayments         FeePayment[]
  placementRecord     PlacementRecord?
  interventions       AcademicIntervention[]
  academicRisk        AcademicRisk?
  submissions         AssignmentSubmission[]
  attendanceFlags     AttendanceFlag[]
  attendance          AttendanceRecord[]
  careerAudits        CareerPathAudit[]
  sharedResources     CollaborationResource[]
  complaints          Complaint[]
  facultyFeedback     FacultyFeedback[]
  grantApplications   GrantApplication[]
  industryReadiness   IndustryReadiness?
  marksComplaints     MarksComplaint[]
  mentorProfile       MentorProfile?
  mentorshipsAsMentee MentorshipRelation[]        @relation("MenteeRelation")
  quizAttempts        QuizAttempt[]
  reassessments       ReassessmentRequest[]
  results             Result[]
  serviceRequests     ServiceRequest[]
  divisionAssignments StudentDivisionAssignment[]
  electiveMappings    StudentElectiveMapping[]
  transferLogs        StudentTransferLog[]
  batch               Batch                       @relation(fields: [batchId], references: [id])
  department          Department                  @relation(fields: [departmentId], references: [id])
  program             Program                     @relation(fields: [programId], references: [id])
  university          University                  @relation(fields: [universityId], references: [id])
  user                User?                       @relation(fields: [userId], references: [id])
  studyGroupMembers   StudyGroupMember[]

  @@index([universityId, departmentId, batchId])
  @@map("students")
}

model AttendanceSession {
  id              String             @id @default(uuid())
  timetableSlotId String
  date            DateTime
  method          String
  qrToken         String?            @unique
  openedAt        DateTime
  closedAt        DateTime?
  timetableSlot   TimetableSlot      @relation(fields: [timetableSlotId], references: [id])
  records         AttendanceRecord[]
}

model AttendanceRecord {
  id        String            @id @default(uuid())
  sessionId String
  studentId String
  status    String
  method    String
  markedAt  DateTime
  flagId    String?
  flag      AttendanceFlag?   @relation(fields: [flagId], references: [id])
  session   AttendanceSession @relation(fields: [sessionId], references: [id])
  student   Student           @relation(fields: [studentId], references: [id])

  @@map("attendance_records")
}

model AttendanceFlag {
  id          String             @id @default(uuid())
  studentId   String
  startDate   DateTime
  endDate     DateTime
