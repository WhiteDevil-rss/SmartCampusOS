generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model University {
  id                    String                 @id @default(uuid())
  name                  String
  shortName             String                 @unique
  location              String?
  email                 String?
  estYear               Int?
  website               String?
  adminUserId           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  books                 Book[]
  companies             Company[]
  feeStructures         FeeStructure[]
  publicPortalConfig    PublicPortalConfig?
  verificationRequests  VerificationRequest[]
  admissionApplications AdmissionApplication[]
  batches               Batch[]
  complaints            Complaint[]
  courses               Course[]
  departments           Department[]
  events                Event[]
  faculty               Faculty[]
  programs              Program[]
  resources             Resource[]
  students              Student[]
  timetables            Timetable[]
  users                 User[]
  scholarships          Scholarship[]

  @@map("universities")
}

model Department {
  id                    String                 @id @default(uuid())
  universityId          String
  name                  String
  shortName             String
  hod                   String?
  email                 String?
  adminUserId           String?
  createdAt             DateTime               @default(now())
  books                 Book[]
  admissionApplications AdmissionApplication[]
  admissionInquiries    AdmissionInquiry[]
  batches               Batch[]
  courses               Course[]
  university            University             @relation(fields: [universityId], references: [id], onDelete: Cascade)
  electiveBaskets       ElectiveBasket[]
  faculty               FacultyDepartment[]
  programs              Program[]
  sessionTypes          SessionType[]
  students              Student[]
  timeBlocks            TimeBlock[]
  timetables            Timetable[]
  studyGroups           StudyGroup[]

  @@index([universityId])
  @@map("departments")
}

model FacultyDepartment {
  facultyId    String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  faculty      Faculty    @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@id([facultyId, departmentId])
  @@map("faculty_departments")
}

model Faculty {
  id               String                @id @default(uuid())
  universityId     String
  name             String
  email            String                @unique
  phone            String?
  designation      String?
  qualifications   String?
  experience       String?
  userId           String?
  availability     Json?
  createdAt        DateTime              @default(now())
  payrollConfigId  String?               @unique
  salarySlips      SalarySlip[]
  assignments      Assignment[]
  classes          Class[]
  taughtDivisions  Division[]            @relation("DivisionTeacher")
  faculty1Pairs    ElectiveFacultyPair[] @relation("Faculty1Pairs")
  faculty2Pairs    ElectiveFacultyPair[] @relation("Faculty2Pairs")
  electiveOptions  ElectiveOption[]
  payrollConfig    PayrollConfig?        @relation(fields: [payrollConfigId], references: [id])
  university       University            @relation(fields: [universityId], references: [id], onDelete: Cascade)
  user             User?                 @relation(fields: [userId], references: [id])
  departments      FacultyDepartment[]
  feedback         FacultyFeedback[]
  subjects         FacultySubject[]
  quizzes          Quiz[]
  studyMaterials   StudyMaterial[]
  timetableChanges TimetableChange[]
  faculty2Slots    TimetableSlot[]       @relation("Faculty2Slots")
  timetableSlots   TimetableSlot[]
  publications     Publication[]
  grants           ResearchGrant[]

  @@index([universityId])
  @@map("faculties")
}

model FacultyFeedback {
  id           String   @id @default(uuid())
  facultyId    String
  studentId    String
  rating       Int
  comment      String?
  semester     Int
  academicYear String
  createdAt    DateTime @default(now())
  faculty      Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([facultyId, studentId, semester, academicYear])
  @@map("faculty_feedback")
}

model FacultySubject {
  id               String  @id @default(uuid())
  facultyId        String
  courseId         String
  isPrimary        Boolean @default(true)
  proficiencyLevel Int     @default(5)
  course           Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  faculty          Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@unique([facultyId, courseId])
  @@map("faculty_subjects")
}

model Publication {
  id              String   @id @default(uuid())
  facultyId       String
  title           String
  abstract        String?  @db.Text
  journal         String?
  doi             String?  @unique
  publicationDate DateTime
  citationsCount  Int      @default(0)
  impactFactor    Float?
  url             String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  faculty         Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@index([facultyId])
  @@map("publications")
}

model ResearchGrant {
  id            String   @id @default(uuid())
  facultyId     String
  title         String
  agency        String
  amount        Float
  status        String   @default("PENDING") // PENDING, ACTIVE, COMPLETED, REJECTED
  description   String?  @db.Text
  startDate     DateTime
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  faculty       Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@index([facultyId])
  @@map("research_grants")
}

model Course {
  id               String           @id @default(uuid())
  departmentId     String?
  universityId     String
  name             String
  code             String
  program          String?
  credits          Int              @default(4)
  weeklyHrs        Int              @default(4)
  semester         Int?
  type             String           @default("Theory")
  sessionTypeId    String?
  labDuration      Int              @default(60)
  requiredRoomType String?
  isElective       Boolean          @default(false)
  createdAt        DateTime         @default(now())
  assignments      Assignment[]
  classes          Class[]
  department       Department?      @relation(fields: [departmentId], references: [id])
  sessionType      SessionType?     @relation("CourseToSessionType", fields: [sessionTypeId], references: [id])
  university       University       @relation(fields: [universityId], references: [id], onDelete: Cascade)
  electiveOptions  ElectiveOption[]
  facultySubjects  FacultySubject[]
  quizzes          Quiz[]
  studyMaterials   StudyMaterial[]
  subjectResults   SubjectResult[]
  timetableSlots   TimetableSlot[]

  @@index([universityId, departmentId])
  @@map("courses")
}

model Batch {
  id             String          @id @default(uuid())
  departmentId   String?
  universityId   String
  name           String
  program        String?
  semester       Int?
  year           String?
  createdAt      DateTime        @default(now())
  assignments    Assignment[]
  department     Department?     @relation(fields: [departmentId], references: [id])
  university     University      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  divisions      Division[]
  students       Student[]
  studyMaterials StudyMaterial[]
  timetableSlots TimetableSlot[]
  timetables     Timetable[]

  @@index([universityId, departmentId])
  @@map("batches")
}

model Resource {
  id               String            @id @default(uuid())
  universityId     String
  name             String
  type             String
  capacity         Int               @default(30)
  floor            String?
  building         String?
  createdAt        DateTime          @default(now())
  primaryDivisions Division[]
  university       University        @relation(fields: [universityId], references: [id], onDelete: Cascade)
  timetableChanges TimetableChange[]
  timetableSlots   TimetableSlot[]

  @@map("resources")
}

model Program {
  id                    String                 @id @default(uuid())
  universityId          String
  departmentId          String?
  name                  String
  shortName             String
  type                  String
  duration              Int                    @default(2)
  totalSems             Int                    @default(4)
  feeStructures         FeeStructure[]
  admissionApplications AdmissionApplication[]
  department            Department?            @relation(fields: [departmentId], references: [id])
  university            University             @relation(fields: [universityId], references: [id], onDelete: Cascade)
  results               Result[]
  students              Student[]

  @@map("programs")
}

model TimeBlock {
  id             String          @id @default(uuid())
  departmentId   String
  name           String
  startTime      String
  endTime        String
  duration       Int
  isBreak        Boolean         @default(false)
  slotNumber     Int             @default(1)
  createdAt      DateTime        @default(now())
  department     Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  timetableSlots TimetableSlot[]

  @@map("time_blocks")
}

model SessionType {
  id               String          @id @default(uuid())
  departmentId     String
  name             String
  durationRule     Int             @default(60)
  roomTypeRequired String?
  createdAt        DateTime        @default(now())
  courses          Course[]        @relation("CourseToSessionType")
  department       Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  timetableSlots   TimetableSlot[]

  @@map("session_types")
}

model ElectiveBasket {
  id              String                   @id @default(uuid())
  departmentId    String
  subjectCode     String
  name            String
  semester        Int?
  program         String?
  weeklyHrs       Int                      @default(2)
  createdAt       DateTime                 @default(now())
  department      Department               @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  facultyPairs    ElectiveFacultyPair[]
  options         ElectiveOption[]
  studentMappings StudentElectiveMapping[]

  @@map("elective_baskets")
}

model ElectiveFacultyPair {
  id         String         @id @default(uuid())
  basketId   String
  faculty1Id String
  faculty2Id String
  dayOfWeek  Int
  createdAt  DateTime       @default(now())
  basket     ElectiveBasket @relation(fields: [basketId], references: [id], onDelete: Cascade)
  faculty1   Faculty        @relation("Faculty1Pairs", fields: [faculty1Id], references: [id])
  faculty2   Faculty        @relation("Faculty2Pairs", fields: [faculty2Id], references: [id])

  @@map("elective_faculty_pairs")
}

model ElectiveOption {
  id              String                   @id @default(uuid())
  basketId        String
  courseId        String
  facultyId       String?
  enrollmentCount Int                      @default(30)
  createdAt       DateTime                 @default(now())
  basket          ElectiveBasket           @relation(fields: [basketId], references: [id], onDelete: Cascade)
  course          Course                   @relation(fields: [courseId], references: [id])
  faculty         Faculty?                 @relation(fields: [facultyId], references: [id])
  subgroups       ElectiveSubgroup[]
  studentMappings StudentElectiveMapping[]

  @@map("elective_options")
}

model ElectiveSubgroup {
  id              String         @id @default(uuid())
  optionId        String
  subgroupId      String
  enrollmentCount Int            @default(30)
  createdAt       DateTime       @default(now())
  option          ElectiveOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@map("elective_subgroups")
}

model Timetable {
  id            String          @id @default(uuid())
  universityId  String
  departmentId  String?
  batchId       String?
  name          String?
  isSpecial     Boolean         @default(false)
  status        String          @default("ACTIVE")
  configJson    Json?
  generatedBy   String          @default("AI")
  version       Int             @default(1)
  conflictCount Int             @default(0)
  generationMs  Int?
  createdAt     DateTime        @default(now())
  divisionId    String?
  slots         TimetableSlot[]
  batch         Batch?          @relation(fields: [batchId], references: [id])
  department    Department?     @relation(fields: [departmentId], references: [id])
  division      Division?       @relation(fields: [divisionId], references: [id])
  university    University      @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@map("timetables")
}

model TimetableSlot {
  id                 String              @id @default(uuid())
  timetableId        String
  dayOfWeek          Int
  slotNumber         Int
  startTime          String
  endTime            String
  courseId           String?
  facultyId          String?
  faculty2Id         String?
  roomId             String?
  divisionId         String
  batchId            String?
  blockId            String?
  sessionTypeId      String?
  isBreak            Boolean             @default(false)
  slotType           String              @default("THEORY")
  isElective         Boolean             @default(false)
  basketId           String?
  optionId           String?
  classId            String?
  attendanceSessions AttendanceSession[]
  timetableChanges   TimetableChange[]
  batch              Batch?              @relation(fields: [batchId], references: [id])
  block              TimeBlock?          @relation(fields: [blockId], references: [id])
  class              Class?              @relation(fields: [classId], references: [id])
  course             Course?             @relation(fields: [courseId], references: [id])
  division           Division            @relation(fields: [divisionId], references: [id])
  faculty2           Faculty?            @relation("Faculty2Slots", fields: [faculty2Id], references: [id])
  faculty            Faculty?            @relation(fields: [facultyId], references: [id])
  room               Resource?           @relation(fields: [roomId], references: [id])
  sessionType        SessionType?        @relation(fields: [sessionTypeId], references: [id])
  timetable          Timetable           @relation(fields: [timetableId], references: [id], onDelete: Cascade)

  @@map("timetable_slots")
}

model User {
  id                   String                 @id @default(uuid())
  username             String                 @unique
  email                String?                @unique
  passwordHash         String?
  firebaseUid          String?                @unique
  role                 String
  entityId             String?
  universityId         String?
  phoneNumber          String?
  address              String?
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  lastLogin            DateTime?
  fcmToken             String?
  reviewerApplications AdmissionApplication[] @relation("ReviewerApplications")
  assignedInquiries    AdmissionInquiry[]     @relation("AssignedInquiries")
  logs                 AuditLog[]
  faculty              Faculty[]
  messageHistory       MessageHistory[]
  syncLogs             MessageSyncLog[]
  messages             Message[]
  notifications        Notification[]
  permissions          Permission[]
  performedTransfers   StudentTransferLog[]   @relation("PerformedTransfers")
  addedSubscribers     Subscriber[]           @relation("UserSubscribers")
  subscription         SubscriptionControl?
  student              Student?
  university           University?            @relation(fields: [universityId], references: [id], onDelete: Cascade)
  threads              ChatThread[]           @relation("ThreadParticipants")

  @@map("users")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  changes    Json?
  status     String   @default("SUCCESS")
  endpoint   String?
  method     String?
  durationMs Int?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model GlobalSettings {
  id              String   @id @default("system-config")
  platformName    String   @default("SmartCampus OS")
  supportEmail    String   @default("support@smartcampus.ac.in")
  maintenanceMode Boolean  @default(false)
  sessionTimeout  Int      @default(600)
  mfaEnabled      Boolean  @default(false)
  logRetention    String   @default("30")
  autoBackups     Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  @@map("global_settings")
}

model Inquiry {
  id            String   @id @default(uuid())
  name          String?
  email         String
  contactNumber String?
  organization  String?
  message       String?
  source        String?  @default("get_started_popup")
  status        String   @default("NEW")
  ipAddress     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("inquiries")
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  status    String   @default("ACTIVE")
  creatorId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creator   User?    @relation("UserSubscribers", fields: [creatorId], references: [id])

  @@map("subscribers")
}

model Permission {
  id           String   @id @default(uuid())
  roleId       String
  userId       String?
  module       String
  action       String
  allowed      Boolean  @default(false)
  restrictions Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action])
  @@map("permissions")
}

model SubscriptionControl {
  id                 String    @id @default(uuid())
  userId             String    @unique
  canSubscribe       Boolean   @default(true)
  subscriptionLimit  Int       @default(100)
  subscriptionExpiry DateTime?
  autoRenew          Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscription_controls")
}

model PublicPortalConfig {
  id           String     @id @default(uuid())
  universityId String     @unique
  slug         String     @unique
  customDomain String?
  branding     Json
  features     Json
  rateLimits   Json
  updatedAt    DateTime   @updatedAt
  university   University @relation(fields: [universityId], references: [id])
}

model Student {
  id                  String                      @id @default(uuid())
  universityId        String
  departmentId        String
  enrollmentNo        String                      @unique
  name                String
  email               String                      @unique
  phone               String?
  batchId             String
  programId           String
  admissionYear       Int
  photoUrl            String?
  bookLoans           BookLoan[]
  feePayments         FeePayment[]
  placementRecord     PlacementRecord?
  submissions         AssignmentSubmission[]
  attendanceFlags     AttendanceFlag[]
  attendance          AttendanceRecord[]
  complaints          Complaint[]
  facultyFeedback     FacultyFeedback[]
  marksComplaints     MarksComplaint[]
  quizAttempts        QuizAttempt[]
  reassessments       ReassessmentRequest[]
  results             Result[]
  serviceRequests     ServiceRequest[]
  divisionAssignments StudentDivisionAssignment[]
  electiveMappings    StudentElectiveMapping[]
  transferLogs        StudentTransferLog[]
  batch               Batch                       @relation(fields: [batchId], references: [id])
  department          Department                  @relation(fields: [departmentId], references: [id])
  program             Program                     @relation(fields: [programId], references: [id])
  university          University                  @relation(fields: [universityId], references: [id])
  userId              String?                     @unique
  user                User?                       @relation(fields: [userId], references: [id])
  grantApplications   GrantApplication[]
  academicRisk        AcademicRisk?
  interventions       AcademicIntervention[]
  mentorProfile       MentorProfile?
  mentorshipsAsMentee MentorshipRelation[]        @relation("MenteeRelation")
  studyGroupMembers   StudyGroupMember[]
  sharedResources     CollaborationResource[]

  @@index([universityId, departmentId, batchId])
  @@map("students")
}

model AttendanceSession {
  id              String             @id @default(uuid())
  timetableSlotId String
  date            DateTime
  method          String
  qrToken         String?            @unique
  openedAt        DateTime
  closedAt        DateTime?
  timetableSlot   TimetableSlot      @relation(fields: [timetableSlotId], references: [id])
  records         AttendanceRecord[]
}

model AttendanceRecord {
  id        String            @id @default(uuid())
  sessionId String
  studentId String
  status    String
  method    String
  markedAt  DateTime
  flagId    String?
  flag      AttendanceFlag?   @relation(fields: [flagId], references: [id])
  session   AttendanceSession @relation(fields: [sessionId], references: [id])
  student   Student           @relation(fields: [studentId], references: [id])

  @@map("attendance_records")
}

model AttendanceFlag {
  id          String             @id @default(uuid())
  studentId   String
  startDate   DateTime
  endDate     DateTime
  flagType    String
  reason      String?
  documentUrl String?
  status      String             @default("PENDING")
  appliedAt   DateTime           @default(now())
  approvedBy  String?
  approvedAt  DateTime?
  student     Student            @relation(fields: [studentId], references: [id])
  records     AttendanceRecord[]

  @@map("attendance_flags")
}

model Result {
  id                    String          @id @default(uuid())
  studentId             String
  programId             String
  semester              Int
  academicYear          String
  sgpa                  Float
  cgpa                  Float
  status                String          @default("PASS")
  resultHash            String
  publishedAt           DateTime?
  blockchainTxHash      String?
  blockchainConfirmedAt DateTime?
  program               Program         @relation(fields: [programId], references: [id])
  student               Student         @relation(fields: [studentId], references: [id])
  subjectResults        SubjectResult[]

  @@map("results")
}

model SubjectResult {
  id            String                @id @default(uuid())
  resultId      String
  courseId      String
  internalMarks Float?
  midTermMarks  Float?
  externalMarks Float?
  totalMarks    Float
  status        String                @default("DRAFT")
  grade         String
  creditsEarned Float
  complaints    MarksComplaint[]
  reassessments ReassessmentRequest[]
  course        Course                @relation(fields: [courseId], references: [id])
  result        Result                @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@unique([resultId, courseId])
  @@map("subject_results")
}

model MarksComplaint {
  id              String        @id @default(uuid())
  studentId       String
  subjectResultId String
  description     String
  status          String        @default("PENDING")
  resolution      String?
  logs            Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  student         Student       @relation(fields: [studentId], references: [id])
  subjectResult   SubjectResult @relation(fields: [subjectResultId], references: [id])

  @@map("marks_complaints")
}

model ReassessmentRequest {
  id              String        @id @default(uuid())
  studentId       String
  subjectResultId String
  reason          String?
  status          String        @default("PENDING")
  oldMarks        Float?
  newMarks        Float?
  paymentStatus   String        @default("PENDING")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  student         Student       @relation(fields: [studentId], references: [id])
  subjectResult   SubjectResult @relation(fields: [subjectResultId], references: [id])

  @@map("reassessment_requests")
}

model VerificationRequest {
  id              String     @id @default(uuid())
  universityId    String
  enrollmentNo    String
  requesterIp     String
  requestType     String
  verifiedAt      DateTime   @default(now())
  blockchainMatch Boolean
  resultSnapshot  Json?
  university      University @relation(fields: [universityId], references: [id])
}

model FeeStructure {
  id           String       @id @default(uuid())
  universityId String
  programId    String
  semester     Int
  academicYear String
  components   Json
  totalAmount  Float
  payments     FeePayment[]
  program      Program      @relation(fields: [programId], references: [id])
  university   University   @relation(fields: [universityId], references: [id])
}

model FeePayment {
  id             String       @id @default(uuid())
  studentId      String
  feeStructureId String
  amount         Float
  paymentDate    DateTime
  method         String
  transactionId  String?
  status         String
  gateway        String?
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id])
}

model Scholarship {
  id           String             @id @default(uuid())
  universityId String
  name         String
  provider     String
  description  String?
  amount       Float
  minGpa       Float              @default(0.0)
  maxBacklogs  Int                @default(0)
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  university   University         @relation(fields: [universityId], references: [id], onDelete: Cascade)
  applications GrantApplication[]

  @@map("scholarships")
}

model GrantApplication {
  id            String      @id @default(uuid())
  studentId     String
  scholarshipId String
  status        String      @default("PENDING") // PENDING, APPROVED, REJECTED, DISBURSED
  appliedAt     DateTime    @default(now())
  approvedAt    DateTime?
  disbursedAt   DateTime?
  remarks       String?
  scholarship   Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, scholarshipId])
  @@map("grant_applications")
}

model AcademicRisk {
  id           String   @id @default(uuid())
  studentId    String   @unique
  riskLevel    String   // SAFE, AT_RISK, CRITICAL
  score        Float    // 0-100 index (Higher = Higher Risk)
  factors      Json     // Detailed breakdown of risk factors (e.g. {attendance: -15, sgpaTrend: -10})
  lastAnalyzed DateTime @default(now())
  student      Student  @relation(fields: [studentId], references: [id])

  @@map("academic_risks")
}

model AcademicIntervention {
  id           String    @id @default(uuid())
  studentId    String
  title        String
  description  String
  status       String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  type         String    // TUTORIAL, COUNSELING, RESOURCE
  prescribedBy String    @default("AI_SENTINEL")
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
  student      Student   @relation(fields: [studentId], references: [id])

  @@map("academic_interventions")
}

model MentorProfile {
  id           String               @id @default(uuid())
  studentId    String               @unique
  isActive     Boolean              @default(true)
  bio          String?
  expertise    Json                 // Array of subject codes/names
  rating       Float                @default(5.0)
  totalHours   Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  student      Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mentorships  MentorshipRelation[]

  @@map("mentor_profiles")
}

model MentorshipRelation {
  id              String         @id @default(uuid())
  mentorProfileId String
  menteeId        String
  subject         String
  status          String         @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  startedAt       DateTime       @default(now())
  completedAt     DateTime?
  notes           String?
  mentorProfile   MentorProfile  @relation(fields: [mentorProfileId], references: [id])
  mentee          Student        @relation("MenteeRelation", fields: [menteeId], references: [id])

  @@map("mentorship_relations")
}

model StudyGroup {
  id           String             @id @default(uuid())
  departmentId String
  title        String
  description  String?
  subject      String?
  isPrivate    Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  department   Department         @relation(fields: [departmentId], references: [id])
  members      StudyGroupMember[]
  resources    CollaborationResource[]

  @@map("study_groups")
}

model StudyGroupMember {
  id           String     @id @default(uuid())
  groupId      String
  studentId    String
  role         String     @default("MEMBER") // ADMIN, MEMBER
  joinedAt     DateTime   @default(now())
  group        StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
  @@map("study_group_members")
}

model CollaborationResource {
  id           String      @id @default(uuid())
  studentId    String
  groupId      String?
  title        String
  description  String?
  fileUrl      String
  fileType     String
  subject      String?
  rating       Float       @default(0.0)
  downloadCount Int        @default(0)
  createdAt    DateTime    @default(now())
  student      Student     @relation(fields: [studentId], references: [id])
  group        StudyGroup? @relation(fields: [groupId], references: [id])

  @@map("collaboration_resources")
}

model Book {
  id              String            @id @default(uuid())
  universityId    String
  isbn            String
  title           String
  author          String
  departmentId    String?
  category        String
  totalCopies     Int
  availableCopies Int
  department      Department?       @relation(fields: [departmentId], references: [id])
  university      University        @relation(fields: [universityId], references: [id])
  loans           BookLoan[]
  reservations    BookReservation[]
}

model BookLoan {
  id         String    @id @default(uuid())
  studentId  String
  bookId     String
  issuedAt   DateTime
  dueDate    DateTime
  returnedAt DateTime?
  fineAmount Float?
  book       Book      @relation(fields: [bookId], references: [id])
  student    Student   @relation(fields: [studentId], references: [id])
}

model BookReservation {
  id         String   @id @default(uuid())
  studentId  String
  bookId     String
  reservedAt DateTime
  expiresAt  DateTime
  book       Book     @relation(fields: [bookId], references: [id])
}

model Company {
  id           String            @id @default(uuid())
  universityId String
  name         String
  type         String
  hrContact    String?
  website      String?
  university   University        @relation(fields: [universityId], references: [id])
  placements   PlacementRecord[]
}

model PlacementRecord {
  id        String   @id @default(uuid())
  studentId String   @unique
  companyId String
  placedAt  DateTime
  ctc       Float
  role      String
  company   Company  @relation(fields: [companyId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])
}

model AdmissionApplication {
  id                 String            @id @default(uuid())
  applicationId      String            @unique
  universityId       String
  departmentId       String
  programId          String
  applicantName      String
  email              String
  phone              String?
  documents          Json              @default("{}")
  status             String            @default("PENDING")
  priority           String            @default("NORMAL")
  assignedReviewerId String?
  remarks            String?
  internalNotes      Json?             @default("[]")
  timeline           Json?             @default("[]")
  decisionDate       DateTime?
  enrollmentDate     DateTime?
  appliedAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  assignedReviewer   User?             @relation("ReviewerApplications", fields: [assignedReviewerId], references: [id])
  department         Department        @relation(fields: [departmentId], references: [id])
  program            Program           @relation(fields: [programId], references: [id])
  university         University        @relation(fields: [universityId], references: [id])
  inquiry            AdmissionInquiry? @relation("InquiryToApplication")

  @@map("admission_applications")
}

model AdmissionInquiry {
  id                       String                @id @default(uuid())
  inquiryId                String                @unique
  departmentId             String
  courseId                 String?
  name                     String
  email                    String
  phone                    String?
  country                  String?
  message                  String
  status                   String                @default("NEW")
  priority                 String                @default("MEDIUM")
  assignedToId             String?
  convertedToApplicationId String?               @unique
  submittedAt              DateTime              @default(now())
  resolvedAt               DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  assignedTo               User?                 @relation("AssignedInquiries", fields: [assignedToId], references: [id])
  convertedToApplication   AdmissionApplication? @relation("InquiryToApplication", fields: [convertedToApplicationId], references: [id])
  department               Department            @relation(fields: [departmentId], references: [id])

  @@map("admission_inquiries")
}

model Assignment {
  id          String                 @id @default(uuid())
  title       String
  description String?
  attachments Json?
  dueDate     DateTime
  maxMarks    Int                    @default(100)
  facultyId   String
  courseId    String
  batchId     String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  submissions AssignmentSubmission[]
  batch       Batch?                 @relation(fields: [batchId], references: [id])
  course      Course                 @relation(fields: [courseId], references: [id])
  faculty     Faculty                @relation(fields: [facultyId], references: [id])

  @@map("assignments")
}

model AssignmentSubmission {
  id              String     @id @default(uuid())
  assignmentId    String
  studentId       String
  fileUrl         String
  submittedAt     DateTime   @default(now())
  grade           Float?
  feedback        String?
  plagiarismScore Float?
  status          String     @default("SUBMITTED")
  assignment      Assignment @relation(fields: [assignmentId], references: [id])
  student         Student    @relation(fields: [studentId], references: [id])

  @@map("assignment_submissions")
}

model StudyMaterial {
  id          String   @id @default(uuid())
  title       String
  description String?
  fileUrl     String
  fileType    String?
  facultyId   String
  courseId    String
  batchId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  batch       Batch?   @relation(fields: [batchId], references: [id])
  course      Course   @relation(fields: [courseId], references: [id])
  faculty     Faculty  @relation(fields: [facultyId], references: [id])

  @@map("study_materials")
}

model Quiz {
  id          String        @id @default(uuid())
  title       String
  description String?
  timeLimit   Int
  facultyId   String
  courseId    String
  createdAt   DateTime      @default(now())
  questions   Question[]
  attempts    QuizAttempt[]
  course      Course        @relation(fields: [courseId], references: [id])
  faculty     Faculty       @relation(fields: [facultyId], references: [id])

  @@map("quizzes")
}

model Question {
  id            String  @id @default(uuid())
  quizId        String
  type          String  @default("MCQ")
  text          String
  options       Json?
  correctAnswer String?
  marks         Int     @default(1)
  quiz          Quiz    @relation(fields: [quizId], references: [id])

  @@map("questions")
}

model QuizAttempt {
  id          String    @id @default(uuid())
  quizId      String
  studentId   String
  score       Float?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  quiz        Quiz      @relation(fields: [quizId], references: [id])
  student     Student   @relation(fields: [studentId], references: [id])

  @@map("quiz_attempts")
}

model ServiceRequest {
  id          String   @id @default(uuid())
  studentId   String
  type        String
  status      String   @default("PENDING")
  description String?
  attachments Json?
  approvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  student     Student  @relation(fields: [studentId], references: [id])

  @@map("service_requests")
}

model Complaint {
  id           String     @id @default(uuid())
  universityId String
  studentId    String?
  category     String
  subject      String
  description  String
  recipient    String?
  status       String     @default("OPEN")
  isAnonymous  Boolean    @default(false)
  resolution   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  student      Student?   @relation(fields: [studentId], references: [id])
  university   University @relation(fields: [universityId], references: [id])

  @@map("complaints")
}

model ChatThread {
  id           String    @id @default(uuid())
  type         String    @default("DIRECT")
  title        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
  participants User[]    @relation("ThreadParticipants")

  @@map("chat_threads")
}

model Message {
  id        String     @id @default(uuid())
  threadId  String
  senderId  String
  content   String
  type      String     @default("TEXT")
  fileUrl   String?
  isRead    Boolean    @default(false)
  createdAt DateTime   @default(now())
  sender    User       @relation(fields: [senderId], references: [id])
  thread    ChatThread @relation(fields: [threadId], references: [id])

  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  category  String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model MessageHistory {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  content   String
  link      String?
  source    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("message_history")
}

model MessageSyncLog {
  id           String   @id @default(uuid())
  userId       String
  lastSyncAt   DateTime @default(now())
  syncStatus   String   @default("SUCCESS")
  offlineCount Int      @default(0)
  deviceInfo   String?
  user         User     @relation(fields: [userId], references: [id])

  @@map("message_sync_logs")
}

model Event {
  id           String     @id @default(uuid())
  universityId String
  title        String
  description  String
  type         String
  startDate    DateTime
  endDate      DateTime
  location     String?
  budget       Float?
  isPublic     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  university   University @relation(fields: [universityId], references: [id])

  @@map("events")
}

model PayrollConfig {
  id           String   @id @default(uuid())
  universityId String
  facultyId    String   @unique
  baseSalary   Float
  allowances   Json     @default("{}")
  deductions   Json     @default("{}")
  bankAccount  String?
  ifscCode     String?
  taxId        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  faculty      Faculty?
}

model SalarySlip {
  id            String   @id @default(uuid())
  facultyId     String
  month         Int
  year          Int
  baseSalary    Float
  allowances    Json
  deductions    Json
  grossAmount   Float
  netAmount     Float
  paymentDate   DateTime @default(now())
  status        String   @default("PAID")
  transactionId String?
  createdAt     DateTime @default(now())
  faculty       Faculty  @relation(fields: [facultyId], references: [id])
}

model StudentElectiveMapping {
  id        String         @id @default(uuid())
  studentId String
  basketId  String
  optionId  String
  createdAt DateTime       @default(now())
  basket    ElectiveBasket @relation(fields: [basketId], references: [id], onDelete: Cascade)
  option    ElectiveOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  student   Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, basketId])
  @@map("student_elective_mappings")
}

model TimetableChange {
  id                  String        @id @default(uuid())
  originalSlotId      String
  substituteFacultyId String?
  newRoomId           String?
  date                DateTime
  reason              String?
  approvedBy          String?
  notificationSent    Boolean       @default(false)
  createdAt           DateTime      @default(now())
  newRoom             Resource?     @relation(fields: [newRoomId], references: [id])
  originalSlot        TimetableSlot @relation(fields: [originalSlotId], references: [id], onDelete: Cascade)
  substituteFaculty   Faculty?      @relation(fields: [substituteFacultyId], references: [id])

  @@map("timetable_changes")
}

model JobPosting {
  id             String           @id @default(uuid())
  title          String
  description    String
  type           String           @default("FULL_TIME")
  location       String?
  panelType      String
  panelId        String?
  departmentName String?
  universityName String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  applications   JobApplication[]

  @@map("job_postings")
}

model JobApplication {
  id            String     @id @default(uuid())
  jobId         String
  applicantName String
  email         String
  mobile        String
  resumeUrl     String?
  coverLetter   String?
  status        String     @default("PENDING")
  appliedAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  job           JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_applications")
}

model Division {
  id                 String                      @id @default(uuid())
  batchId            String
  name               String
  capacity           Int                         @default(30)
  classTeacherId     String?
  primaryRoomId      String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  classes            Class[]
  batch              Batch                       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  classTeacher       Faculty?                    @relation("DivisionTeacher", fields: [classTeacherId], references: [id])
  primaryRoom        Resource?                   @relation(fields: [primaryRoomId], references: [id])
  studentAssignments StudentDivisionAssignment[]
  transferLogsFrom   StudentTransferLog[]        @relation("FromTransfers")
  transferLogsTo     StudentTransferLog[]        @relation("ToTransfers")
  timetableSlots     TimetableSlot[]
  timetables         Timetable[]

  @@map("divisions")
}

model Class {
  id             String          @id @default(uuid())
  subjectId      String
  facultyId      String
  divisionId     String
  academicYear   String
  semester       Int
  status         String          @default("ACTIVE")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  division       Division        @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  faculty        Faculty         @relation(fields: [facultyId], references: [id])
  subject        Course          @relation(fields: [subjectId], references: [id])
  timetableSlots TimetableSlot[]

  @@unique([subjectId, divisionId, academicYear, semester])
  @@map("classes")
}

model StudentDivisionAssignment {
  id           String   @id @default(uuid())
  studentId    String
  divisionId   String
  academicYear String
  status       String   @default("ACTIVE")
  assignedAt   DateTime @default(now())
  division     Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, divisionId, academicYear])
  @@map("student_division_assignments")
}

model StudentTransferLog {
  id             String    @id @default(uuid())
  studentId      String
  fromDivisionId String?
  toDivisionId   String
  reason         String?
  actionById     String
  createdAt      DateTime  @default(now())
  actionBy       User      @relation("PerformedTransfers", fields: [actionById], references: [id])
  fromDivision   Division? @relation("FromTransfers", fields: [fromDivisionId], references: [id])
  student        Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  toDivision     Division  @relation("ToTransfers", fields: [toDivisionId], references: [id])

  @@map("student_transfer_logs")
}
