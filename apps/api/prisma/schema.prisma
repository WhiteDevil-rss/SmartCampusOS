generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model University {
  id                    String                 @id @default(uuid())
  name                  String
  shortName             String                 @unique
  location              String?
  email                 String?
  estYear               Int?
  website               String?
  adminUserId           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  departments           Department[]
  programs              Program[]
  resources             Resource[]
  faculty               Faculty[]
  batches               Batch[]
  courses               Course[]
  timetables            Timetable[]
  users                 User[]
  publicPortalConfig    PublicPortalConfig?
  students              Student[]
  verificationRequests  VerificationRequest[]
  feeStructures         FeeStructure[]
  books                 Book[]
  companies             Company[]
  admissionApplications AdmissionApplication[]
  complaints            Complaint[]
  events                Event[]

  @@map("universities")
}

model Department {
  id              String              @id @default(uuid())
  universityId    String
  university      University          @relation(fields: [universityId], references: [id], onDelete: Cascade)
  name            String
  shortName       String
  hod             String?
  email           String?
  adminUserId     String?
  createdAt       DateTime            @default(now())
  faculty         FacultyDepartment[]
  courses         Course[]
  batches         Batch[]
  timetables      Timetable[]
  electiveBaskets ElectiveBasket[]
  programs        Program[]
  timeBlocks      TimeBlock[]
  sessionTypes    SessionType[]
  students        Student[]
  books           Book[]

  @@map("departments")
}

model FacultyDepartment {
  facultyId    String
  departmentId String
  faculty      Faculty    @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([facultyId, departmentId])
  @@map("faculty_departments")
}

model Faculty {
  id             String     @id @default(uuid())
  universityId   String
  university     University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  name           String
  email          String     @unique
  phone          String?
  designation    String?
  qualifications String?
  experience     String?
  userId         String?
  user           User?      @relation(fields: [userId], references: [id])

  // Advanced Constraints for AI Engine
  availability Json? // Blocked slot map: { "Monday": [1, 2], "Friday": [5, 6] }

  createdAt       DateTime              @default(now())
  subjects        FacultySubject[]
  departments     FacultyDepartment[]
  timetableSlots  TimetableSlot[]
  faculty2Slots   TimetableSlot[]       @relation("Faculty2Slots")
  electiveOptions ElectiveOption[]
  faculty1Pairs   ElectiveFacultyPair[] @relation("Faculty1Pairs")
  faculty2Pairs   ElectiveFacultyPair[] @relation("Faculty2Pairs")
  timetableChanges TimetableChange[]
  assignments     Assignment[]
  quizzes         Quiz[]
  studyMaterials  StudyMaterial[]
  payrollConfig   PayrollConfig?  @relation(fields: [payrollConfigId], references: [id])
  payrollConfigId String?         @unique
  salarySlips     SalarySlip[]
  feedback        FacultyFeedback[]

  @@map("faculties")
}

model FacultyFeedback {
  id           String   @id @default(uuid())
  facultyId    String
  studentId    String
  rating       Int      // 1-5
  comment      String?  @db.Text
  semester     Int
  academicYear String
  createdAt    DateTime @default(now())

  faculty      Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([facultyId, studentId, semester, academicYear])
  @@map("faculty_feedback")
}

model FacultySubject {
  id               String  @id @default(uuid())
  facultyId        String
  courseId         String
  faculty          Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  course           Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  isPrimary        Boolean @default(true)
  proficiencyLevel Int     @default(5)

  @@unique([facultyId, courseId])
  @@map("faculty_subjects")
}

model Course {
  id               String           @id @default(uuid())
  departmentId     String?
  universityId     String
  department       Department?      @relation(fields: [departmentId], references: [id])
  university       University       @relation(fields: [universityId], references: [id], onDelete: Cascade)
  name             String
  code             String
  program          String?
  credits          Int              @default(4)
  weeklyHrs        Int              @default(4)
  semester         Int? // e.g. 1, 2, 3, 4 — which semester this subject belongs to
  type             String           @default("Theory") // Theory | Lab | Theory+Lab
  sessionTypeId    String?
  sessionType      SessionType?     @relation("CourseToSessionType", fields: [sessionTypeId], references: [id])
  labDuration      Int              @default(60) // in minutes
  requiredRoomType String? // Classroom | Lab
  isElective       Boolean          @default(false) // Used for parallel track matching
  createdAt        DateTime         @default(now())
  facultySubjects  FacultySubject[]
  timetableSlots   TimetableSlot[]
  electiveOptions  ElectiveOption[]
  assignments      Assignment[]
  quizzes          Quiz[]
  studyMaterials   StudyMaterial[]
  subjectResults   SubjectResult[]

  @@map("courses")
}

model Batch {
  id             String          @id @default(uuid())
  departmentId   String?
  universityId   String
  department     Department?     @relation(fields: [departmentId], references: [id])
  university     University      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  name           String
  program        String?
  semester       Int?
  division       String?
  year           String?
  strength       Int             @default(30) // students in this specific division
  totalStudents  Int             @default(0) // total capacity for the whole batch
  createdAt      DateTime        @default(now())
  timetableSlots TimetableSlot[]
  timetables     Timetable[]
  students       Student[]
  assignments    Assignment[]
  studyMaterials StudyMaterial[]

  @@map("batches")
}

model Resource {
  id             String          @id @default(uuid())
  universityId   String
  university     University      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  name           String
  type           String // Classroom | Lab | Seminar Hall | Auditorium
  capacity       Int             @default(30)
  floor          String?
  building       String?
  createdAt      DateTime        @default(now())
  timetableSlots   TimetableSlot[]
  timetableChanges TimetableChange[]

  @@map("resources")
}

model Program {
  id                    String                 @id @default(uuid())
  universityId          String
  university            University             @relation(fields: [universityId], references: [id], onDelete: Cascade)
  departmentId          String?
  department            Department?            @relation(fields: [departmentId], references: [id])
  name                  String
  shortName             String
  type                  String // UG | PG | Diploma | Ph.D
  duration              Int                    @default(2)
  totalSems             Int                    @default(4)
  students              Student[]
  results               Result[]
  feeStructures         FeeStructure[]
  admissionApplications AdmissionApplication[]

  @@map("programs")
}

model TimeBlock {
  id             String          @id @default(uuid())
  departmentId   String
  department     Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name           String // e.g. "Block 1"
  startTime      String // "10:30"
  endTime        String // "12:30"
  duration       Int // in minutes
  isBreak        Boolean         @default(false)
  slotNumber     Int             @default(1)
  createdAt      DateTime        @default(now())
  timetableSlots TimetableSlot[]

  @@map("time_blocks")
}

model SessionType {
  id               String          @id @default(uuid())
  departmentId     String
  department       Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name             String // Theory | Lab | Practical | Project
  durationRule     Int             @default(60) // Recommended duration in minutes
  roomTypeRequired String? // Classroom | Lab
  createdAt        DateTime        @default(now())
  courses          Course[]        @relation("CourseToSessionType")
  timetableSlots   TimetableSlot[]

  @@map("session_types")
}

model ElectiveBasket {
  id           String                @id @default(uuid())
  departmentId String
  department   Department            @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  subjectCode  String // e.g. "204" – groups elective options under one umbrella
  name         String // e.g. "Semester 4 – Elective Set A"
  semester     Int?
  program      String?
  weeklyHrs    Int                   @default(2)
  createdAt    DateTime              @default(now())
  options      ElectiveOption[]
  facultyPairs ElectiveFacultyPair[]
  studentMappings StudentElectiveMapping[]

  @@map("elective_baskets")
}

model ElectiveFacultyPair {
  id         String         @id @default(uuid())
  basketId   String
  basket     ElectiveBasket @relation(fields: [basketId], references: [id], onDelete: Cascade)
  faculty1Id String
  faculty2Id String
  faculty1   Faculty        @relation("Faculty1Pairs", fields: [faculty1Id], references: [id])
  faculty2   Faculty        @relation("Faculty2Pairs", fields: [faculty2Id], references: [id])
  dayOfWeek  Int // 1=Mon...6=Sat
  createdAt  DateTime       @default(now())

  @@map("elective_faculty_pairs")
}

model ElectiveOption {
  id              String             @id @default(uuid())
  basketId        String
  basket          ElectiveBasket     @relation(fields: [basketId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course             @relation(fields: [courseId], references: [id])
  facultyId       String? // preferred faculty (optional)
  faculty         Faculty?           @relation(fields: [facultyId], references: [id])
  enrollmentCount Int                @default(30) // sub-batch size for room assignment
  createdAt       DateTime           @default(now())
  subgroups       ElectiveSubgroup[]
  studentMappings StudentElectiveMapping[]

  @@map("elective_options")
}

model ElectiveSubgroup {
  id              String         @id @default(uuid())
  optionId        String
  option          ElectiveOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  subgroupId      String // e.g. "Group 1", "Group 2", or "Div A"
  enrollmentCount Int            @default(30) // Splitted size
  createdAt       DateTime       @default(now())

  @@map("elective_subgroups")
}

model Timetable {
  id            String          @id @default(uuid())
  universityId  String
  departmentId  String?
  batchId       String?
  university    University      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  department    Department?     @relation(fields: [departmentId], references: [id])
  batch         Batch?          @relation(fields: [batchId], references: [id])
  name          String?
  isSpecial     Boolean         @default(false)
  status        String          @default("ACTIVE") // ACTIVE | ARCHIVED | DRAFT
  configJson    Json?
  generatedBy   String          @default("AI")
  version       Int             @default(1)
  conflictCount Int             @default(0)
  generationMs  Int?
  createdAt     DateTime        @default(now())
  slots         TimetableSlot[]

  @@map("timetables")
}

model TimetableSlot {
  id            String    @id @default(uuid())
  timetableId   String
  timetable     Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  dayOfWeek     Int // 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat
  slotNumber    Int
  startTime     String // "09:00"
  endTime       String // "10:00"
  courseId      String?
  facultyId     String?
  faculty2Id    String? // For elective pairs
  roomId        String?
  batchId       String
  blockId       String? // Reference to TimeBlock
  sessionTypeId String? // Reference to SessionType

  course      Course?      @relation(fields: [courseId], references: [id])
  faculty     Faculty?     @relation(fields: [facultyId], references: [id])
  faculty2    Faculty?     @relation("Faculty2Slots", fields: [faculty2Id], references: [id])
  room        Resource?    @relation(fields: [roomId], references: [id])
  batch       Batch        @relation(fields: [batchId], references: [id])
  block       TimeBlock?   @relation(fields: [blockId], references: [id])
  sessionType SessionType? @relation(fields: [sessionTypeId], references: [id])

  isBreak  Boolean @default(false)
  slotType String  @default("THEORY") // THEORY | LAB | BREAK | PRACTICAL | PROJECT

  // Elective Metadata
  isElective         Boolean             @default(false)
  basketId           String?
  optionId           String?
  attendanceSessions AttendanceSession[]
  timetableChanges   TimetableChange[]

  @@map("timetable_slots")
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  email         String?        @unique
  passwordHash  String? // Optional now because Firebase handles password
  firebaseUid   String?        @unique
  role          String // SUPERADMIN | UNI_ADMIN | DEPT_ADMIN | FACULTY
  entityId      String? // universityId | departmentId | facultyId
  universityId  String?
  university    University?    @relation(fields: [universityId], references: [id], onDelete: Cascade)
  faculty       Faculty[]
  phoneNumber   String? // Mandatory for new users, enforced in API
  address       String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  lastLogin     DateTime?
  logs          AuditLog[]
  messages      Message[]
  notifications Notification[]
  threads       ChatThread[]   @relation("ThreadParticipants")
  fcmToken      String?
  permissions   Permission[]
  subscription  SubscriptionControl?
  addedSubscribers Subscriber[] @relation("UserSubscribers")
  messageHistory MessageHistory[]
  syncLogs       MessageSyncLog[]

  @@map("users")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String?
  entityId   String?
  changes    Json?
  status     String   @default("SUCCESS") // SUCCESS | FAILURE
  endpoint   String?
  method     String?
  durationMs Int?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

model GlobalSettings {
  id              String   @id @default("system-config")
  platformName    String   @default("SmartCampus OS")
  supportEmail    String   @default("support@smartcampus.ac.in")
  maintenanceMode Boolean  @default(false)
  sessionTimeout  Int      @default(600)
  mfaEnabled      Boolean  @default(false)
  logRetention    String   @default("30")
  autoBackups     Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  @@map("global_settings")
}

model Inquiry {
  id            String   @id @default(uuid())
  name          String?
  email         String
  contactNumber String?
  organization  String?
  message       String?
  source        String?  @default("get_started_popup")
  status        String   @default("NEW") // NEW | CONTACTED | CONVERTED
  ipAddress     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("inquiries")
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  status    String   @default("ACTIVE") // ACTIVE | UNSUBSCRIBED
  creatorId String?  // Tracks which Admin/User added this subscriber
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator   User?    @relation("UserSubscribers", fields: [creatorId], references: [id])

  @@map("subscribers")
}

model Permission {
  id           String   @id @default(uuid())
  roleId       String   // References UserRole enum ideally, but Prisma stores it as String if not linked to a Role model
  userId       String?  // Optional: for user-specific overrides
  module       String   // e.g., 'USERS', 'SUBSCRIBERS', 'SETTINGS'
  action       String   // e.g., 'READ', 'WRITE', 'DELETE', 'ALL'
  allowed      Boolean  @default(false)
  restrictions Json?    // Additional conditions (e.g., {"departments": ["CS"]})
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action]) // Ensure a role has only one rule per module action
  @@map("permissions")
}

model SubscriptionControl {
  id                 String    @id @default(uuid())
  userId             String    @unique
  canSubscribe       Boolean   @default(true)
  subscriptionLimit  Int       @default(100)
  subscriptionExpiry DateTime?
  autoRenew          Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscription_controls")
}

// ==========================================
// V2.0 NEW MODELS (AI Smart University)
// ==========================================

model PublicPortalConfig {
  id           String     @id @default(uuid())
  universityId String     @unique
  university   University @relation(fields: [universityId], references: [id])
  slug         String     @unique
  customDomain String?
  branding     Json // { logo, primaryColor, secondaryColor, heroImage, tagline }
  features     Json // { resultVerification, admissionPortal, scholarshipPortal, ... }
  rateLimits   Json // { verificationsPerHour, admissionsPerHour }
  updatedAt    DateTime   @updatedAt
}

model Student {
  id              String                 @id @default(uuid())
  universityId    String
  university      University             @relation(fields: [universityId], references: [id])
  departmentId    String
  department      Department             @relation(fields: [departmentId], references: [id])
  enrollmentNo    String                 @unique
  name            String
  email           String                 @unique
  phone           String?
  batchId         String
  batch           Batch                  @relation(fields: [batchId], references: [id])
  programId       String
  program         Program                @relation(fields: [programId], references: [id])
  admissionYear   Int
  photoUrl        String?
  attendance      AttendanceRecord[]
  feePayments     FeePayment[]
  bookLoans       BookLoan[]
  placementRecord PlacementRecord?
  results         Result[]
  quizAttempts    QuizAttempt[]
  submissions     AssignmentSubmission[]
  serviceRequests ServiceRequest[]
  complaints      Complaint[]
  electiveMappings StudentElectiveMapping[]
  attendanceFlags  AttendanceFlag[]
  facultyFeedback  FacultyFeedback[]

  @@map("students")
}

model AttendanceSession {
  id              String             @id @default(uuid())
  timetableSlotId String
  timetableSlot   TimetableSlot      @relation(fields: [timetableSlotId], references: [id])
  date            DateTime
  method          String // MANUAL | QR | IOT_BLE | FACE_RECOGNITION
  qrToken         String?            @unique
  openedAt        DateTime
  closedAt        DateTime?
  records         AttendanceRecord[]
}

model AttendanceRecord {
  id        String            @id @default(uuid())
  sessionId String
  session   AttendanceSession @relation(fields: [sessionId], references: [id])
  studentId String
  student   Student           @relation(fields: [studentId], references: [id])
  status    String // PRESENT | ABSENT | LATE | EXCUSED
  method    String
  markedAt  DateTime
  flagId    String?
  flag      AttendanceFlag?   @relation(fields: [flagId], references: [id])
  
  @@map("attendance_records")
}

model AttendanceFlag {
  id           String            @id @default(uuid())
  studentId    String
  student      Student           @relation(fields: [studentId], references: [id])
  startDate    DateTime
  endDate      DateTime
  flagType     String            // SPORTS_DAY | HACKATHON | OFFICIAL_EVENT | MEDICAL
  reason       String?           @db.Text
  documentUrl  String?           // Link to medical certificate, etc.
  status       String            @default("PENDING") // PENDING | APPROVED | REJECTED
  appliedAt    DateTime          @default(now())
  approvedBy   String?           // Faculty or Admin ID
  approvedAt   DateTime?
  
  // Link to specific records that were flagged/excused (optional, filled upon approval)
  records      AttendanceRecord[]

  @@map("attendance_flags")
}

model Result {
  id                    String    @id @default(uuid())
  studentId             String
  programId             String
  semester              Int
  academicYear          String
  sgpa                  Float
  cgpa                  Float
  status                String    @default("PASS") // PASS | FAIL | DETAINED | WITHHELD
  resultHash            String // SHA-256 of canonical result JSON
  publishedAt           DateTime?
  blockchainTxHash      String? // Polygon L2 transaction hash
  blockchainConfirmedAt DateTime?
  student               Student   @relation(fields: [studentId], references: [id])
  program               Program   @relation(fields: [programId], references: [id])
  subjectResults        SubjectResult[]

  @@map("results")
}

model SubjectResult {
  id              String   @id @default(uuid())
  resultId        String
  result          Result   @relation(fields: [resultId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course   @relation(fields: [courseId], references: [id])
  
  internalMarks   Float?   // e.g., Assignments, quizzes (out of 30)
  midTermMarks    Float?   // e.g., Mid-sem exam (out of 20)
  externalMarks   Float?   // e.g., Final university exam (out of 50)
  totalMarks      Float    // internal + mid + external (out of 100)
  grade           String   // O, A+, A, B+, B, C, P, F
  creditsEarned   Float
  
  @@unique([resultId, courseId])
  @@map("subject_results")
}

model VerificationRequest {
  id              String     @id @default(uuid())
  universityId    String
  enrollmentNo    String
  requesterIp     String
  requestType     String // RESULT | DEGREE | CERTIFICATE
  verifiedAt      DateTime   @default(now())
  blockchainMatch Boolean
  resultSnapshot  Json? // Snapshot of result at verification time
  university      University @relation(fields: [universityId], references: [id])
}

model FeeStructure {
  id           String       @id @default(uuid())
  universityId String
  programId    String
  semester     Int
  academicYear String
  components   Json // [{ name, amount, optional }]
  totalAmount  Float
  payments     FeePayment[]
  university   University   @relation(fields: [universityId], references: [id])
  program      Program      @relation(fields: [programId], references: [id])
}

model FeePayment {
  id             String       @id @default(uuid())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
  amount         Float
  paymentDate    DateTime
  method         String // ONLINE | CASH | DD | SCHOLARSHIP
  transactionId  String?
  status         String // PENDING | COMPLETED | FAILED | REFUNDED
  gateway        String? // RAZORPAY | PAYU
}

model Book {
  id              String            @id @default(uuid())
  universityId    String
  isbn            String
  title           String
  author          String
  departmentId    String?
  category        String
  totalCopies     Int
  availableCopies Int
  loans           BookLoan[]
  reservations    BookReservation[]
  university      University        @relation(fields: [universityId], references: [id])
  department      Department?       @relation(fields: [departmentId], references: [id])
}

model BookLoan {
  id         String    @id @default(uuid())
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id])
  bookId     String
  book       Book      @relation(fields: [bookId], references: [id])
  issuedAt   DateTime
  dueDate    DateTime
  returnedAt DateTime?
  fineAmount Float?
}

model BookReservation {
  id         String   @id @default(uuid())
  studentId  String
  bookId     String
  book       Book     @relation(fields: [bookId], references: [id])
  reservedAt DateTime
  expiresAt  DateTime
}

model Company {
  id           String            @id @default(uuid())
  universityId String
  name         String
  type         String // IT | CORE | FINANCE | STARTUP | MNC
  hrContact    String?
  website      String?
  placements   PlacementRecord[]
  university   University        @relation(fields: [universityId], references: [id])
}

model PlacementRecord {
  id        String   @id @default(uuid())
  studentId String   @unique
  student   Student  @relation(fields: [studentId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  placedAt  DateTime
  ctc       Float
  role      String
}

model AdmissionApplication {
  id            String     @id @default(uuid())
  universityId  String
  departmentId  String?
  programId     String
  applicantName String
  email         String
  phone         String?
  documents     Json // { marksheets, photos, certificates }
  status        String // SUBMITTED | SHORTLISTED | SELECTED | REJECTED | WAITLISTED | ONBOARDED
  remarks       String?
  appliedAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  university    University @relation(fields: [universityId], references: [id])
  program       Program    @relation(fields: [programId], references: [id])
}

model Assignment {
  id          String                 @id @default(uuid())
  title       String
  description String?
  attachments Json? // Array of file URLs/metadata
  dueDate     DateTime
  maxMarks    Int                    @default(100)
  facultyId   String
  faculty     Faculty                @relation(fields: [facultyId], references: [id])
  courseId    String
  course      Course                 @relation(fields: [courseId], references: [id])
  batchId     String?
  batch       Batch?                 @relation(fields: [batchId], references: [id])
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  submissions AssignmentSubmission[]

  @@map("assignments")
}

model AssignmentSubmission {
  id              String     @id @default(uuid())
  assignmentId    String
  assignment      Assignment @relation(fields: [assignmentId], references: [id])
  studentId       String
  student         Student    @relation(fields: [studentId], references: [id])
  fileUrl         String
  submittedAt     DateTime   @default(now())
  grade           Float?
  feedback        String?
  plagiarismScore Float?
  status          String     @default("SUBMITTED") // SUBMITTED | GRADED | LATE

  @@map("assignment_submissions")
}

model StudyMaterial {
  id          String   @id @default(uuid())
  title       String
  description String?
  fileUrl     String
  fileType    String? // PDF, DOCX, Video URL etc.
  facultyId   String
  faculty     Faculty  @relation(fields: [facultyId], references: [id])
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  batchId     String? // Optional: can be restricted to a specific batch
  batch       Batch?   @relation(fields: [batchId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("study_materials")
}

model Quiz {
  id          String        @id @default(uuid())
  title       String
  description String?
  timeLimit   Int // in minutes
  facultyId   String
  faculty     Faculty       @relation(fields: [facultyId], references: [id])
  courseId    String
  course      Course        @relation(fields: [courseId], references: [id])
  createdAt   DateTime      @default(now())
  questions   Question[]
  attempts    QuizAttempt[]

  @@map("quizzes")
}

model Question {
  id            String  @id @default(uuid())
  quizId        String
  quiz          Quiz    @relation(fields: [quizId], references: [id])
  type          String  @default("MCQ") // MCQ | SHORT_ANSWER
  text          String
  options       Json? // For MCQ: ["Opt1", "Opt2", ...]
  correctAnswer String? // For auto-grading MCQ
  marks         Int     @default(1)

  @@map("questions")
}

model QuizAttempt {
  id          String    @id @default(uuid())
  quizId      String
  quiz        Quiz      @relation(fields: [quizId], references: [id])
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  score       Float?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@map("quiz_attempts")
}

model ServiceRequest {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  type        String // BONAFIDE | TRANSCRIPT | ID_CARD | PASS
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED | COMPLETED
  description String?
  attachments Json?
  approvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("service_requests")
}

model Complaint {
  id           String     @id @default(uuid())
  universityId String
  university   University @relation(fields: [universityId], references: [id])
  studentId    String? // Nullable for anonymity
  student      Student?   @relation(fields: [studentId], references: [id])
  category     String // RAGGING | HARASSMENT | INFRASTRUCTURE | ACADEMIC
  subject      String
  description  String
  status       String     @default("OPEN") // OPEN | UNDER_REVIEW | RESOLVED | ESCALATED
  isAnonymous  Boolean    @default(false)
  resolution   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("complaints")
}

model ChatThread {
  id           String    @id @default(uuid())
  type         String    @default("DIRECT") // DIRECT | GROUP
  title        String?
  participants User[]    @relation("ThreadParticipants")
  messages     Message[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("chat_threads")
}

model Message {
  id        String     @id @default(uuid())
  threadId  String
  thread    ChatThread @relation(fields: [threadId], references: [id])
  senderId  String
  sender    User       @relation(fields: [senderId], references: [id])
  content   String
  type      String     @default("TEXT") // TEXT | FILE | IMAGE
  fileUrl   String?
  isRead    Boolean    @default(false)
  createdAt DateTime   @default(now())

  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  category  String // ACADEMIC | ATTENDANCE | FEES | SYSTEM
  isRead    Boolean  @default(false)
  link      String? // Deep link to relevant screen
  createdAt DateTime @default(now())

  @@map("notifications")
}

model MessageHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // NOTIFICATION | ALERT | BROADCAST
  title     String
  content   String   @db.Text
  link      String?
  source    String?  // system-generated, manual-broadcast
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("message_history")
}

model MessageSyncLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  lastSyncAt   DateTime @default(now())
  syncStatus   String   @default("SUCCESS") // SUCCESS | PARTIAL | FAILED
  offlineCount Int      @default(0)
  deviceInfo   String?

  @@map("message_sync_logs")
}

model Event {
  id           String     @id @default(uuid())
  universityId String
  university   University @relation(fields: [universityId], references: [id])
  title        String
  description  String
  type         String // ACADEMIC | CULTURAL | SPORTS | HOLIDAY
  startDate    DateTime
  endDate      DateTime
  location     String?
  budget       Float?
  isPublic     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("events")
}

model PayrollConfig {
  id           String   @id @default(uuid())
  universityId String
  facultyId    String   @unique
  baseSalary   Float
  allowances   Json     @default("{}") // { "HRA": 5000, "DA": 2000 }
  deductions   Json     @default("{}") // { "PF": 1800, "Tax": 1000 }
  bankAccount  String?
  ifscCode     String?
  taxId        String? // PAN, SSN etc.
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  faculty      Faculty? 
}

model SalarySlip {
  id           String   @id @default(uuid())
  facultyId    String
  faculty      Faculty  @relation(fields: [facultyId], references: [id])
  month        Int
  year         Int
  baseSalary   Float
  allowances   Json
  deductions   Json
  grossAmount  Float
  netAmount    Float
  paymentDate  DateTime @default(now())
  status       String   @default("PAID") // PAID | PENDING | VOID
  transactionId String? 
  createdAt    DateTime @default(now())
}

model StudentElectiveMapping {
  id             String         @id @default(uuid())
  studentId      String
  student        Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  basketId       String
  basket         ElectiveBasket @relation(fields: [basketId], references: [id], onDelete: Cascade)
  optionId       String
  option         ElectiveOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@unique([studentId, basketId])
  @@map("student_elective_mappings")
}

model TimetableChange {
  id                    String        @id @default(uuid())
  originalSlotId        String
  originalSlot          TimetableSlot @relation(fields: [originalSlotId], references: [id], onDelete: Cascade)
  substituteFacultyId   String?
  substituteFaculty     Faculty?      @relation(fields: [substituteFacultyId], references: [id])
  newRoomId             String?
  newRoom               Resource?     @relation(fields: [newRoomId], references: [id])
  date                  DateTime
  reason                String?
  approvedBy            String?
  notificationSent      Boolean       @default(false)
  createdAt             DateTime      @default(now())

  @@map("timetable_changes")
}
