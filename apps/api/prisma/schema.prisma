  id           String     @id @default(uuid())
  departmentId String
  checkDate    DateTime   @default(now())
  score        Float
  status       String
  results      Json
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@map("compliance_audits")
}

model CampusAsset {
  id           String              @id @default(uuid())
  universityId String
  name         String
  type         String
  location     String
  status       String              @default("OPERATIONAL")
  healthScore  Int                 @default(100)
  lastService  DateTime            @default(now())
  nextService  DateTime?
  iotDeviceId  String?             @unique
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  university   University          @relation(fields: [universityId], references: [id], onDelete: Cascade)
  tickets      MaintenanceTicket[]

  @@map("campus_assets")
}

model MaintenanceTicket {
  id           String      @id @default(uuid())
  assetId      String
  description  String
  severity     String      @default("LOW")
  status       String      @default("OPEN")
  assignedToId String?
  aiPriority   Float       @default(0.0)
  resolution   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  asset        CampusAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignedTo   User?       @relation("AssignedMaintenance", fields: [assignedToId], references: [id])

  @@map("maintenance_tickets")
}

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String
  category  String
  channels  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("notification_preferences")
}

model NotificationLog {
  id           String   @id @default(uuid())
  userId       String
  channel      String
  category     String?
  status       String   @default("SENT")
  payload      Json
  errorMessage String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_logs")
}

model ConnectRequest {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  message    String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  receiver   User     @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@map("connect_requests")
}

model InventoryItem {
  id           String               @id @default(uuid())
  universityId String
  name         String
  description  String?
  category     String
  stockLevel   Float                @default(0)
  unit         String
  minThreshold Float                @default(10)
  costPerUnit  Float                @default(0)
  expiryDate   DateTime?
  location     String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  university   University           @relation(fields: [universityId], references: [id], onDelete: Cascade)
  procurements ProcurementRequest[]
  logs         StockLog[]

  @@index([universityId])
  @@map("inventory_items")
}

model Vendor {
  id           String               @id @default(uuid())
  universityId String
  name         String
  email        String?
  phone        String?
  address      String?
  category     String
  rating       Float                @default(5.0)
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  procurements ProcurementRequest[]
  university   University           @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId])
  @@map("vendors")
}

model ProcurementRequest {
  id            String        @id @default(uuid())
  universityId  String
  itemId        String
  vendorId      String?
  quantity      Float
  totalCost     Float?
  status        String        @default("PENDING")
  priority      String        @default("MEDIUM")
  requestedById String
  approvedById  String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  approvedBy    User?         @relation("ApprovedBy", fields: [approvedById], references: [id])
  item          InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  requestedBy   User          @relation("RequestedBy", fields: [requestedById], references: [id])
  university    University    @relation(fields: [universityId], references: [id], onDelete: Cascade)
  vendor        Vendor?       @relation(fields: [vendorId], references: [id])

  @@index([universityId, itemId])
  @@map("procurement_requests")
}

model StockLog {
  id            String        @id @default(uuid())
  itemId        String
  quantity      Float
  type          String
  reason        String?
  performedById String
  createdAt     DateTime      @default(now())
  item          InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  performedBy   User          @relation("PerformedBy", fields: [performedById], references: [id])

  @@index([itemId])
  @@map("stock_logs")
}

model SecurityIncident {
  id           String     @id @default(uuid())
  universityId String
  title        String
  description  String
  type         String
  status       String     @default("OPEN")
  severity     String     @default("MEDIUM")
  location     String
  latitude     Float?
  longitude    Float?
  reportedById String
  assignedToId String?
  aiPriority   Int        @default(5)
  aiSummary    String?
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assignedTo   User?      @relation("AssignedTo", fields: [assignedToId], references: [id])
  reportedBy   User       @relation("ReportedBy", fields: [reportedById], references: [id])
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId, status])
  @@map("security_incidents")
}

model EmergencyAlert {
  id           String     @id @default(uuid())
  universityId String
  senderId     String
  title        String
  message      String
  scope        String     @default("CAMPUS_WIDE")
  targetArea   String?
  type         String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId, isActive])
  @@map("emergency_alerts")
}

model PatrolRoute {
  id           String     @id @default(uuid())
  universityId String
  name         String
  points       Json
  officerId    String?
  status       String     @default("INACTIVE")
  startTime    DateTime?
  endTime      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  officer      User?      @relation("PatrolOfficer", fields: [officerId], references: [id])
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId, officerId])
  @@map("patrol_routes")
}

model VisitorLog {
  id           String     @id @default(uuid())
  universityId String
  visitorName  String
  purpose      String
  checkInTime  DateTime   @default(now())
  checkOutTime DateTime?
  hostId       String
  idType       String?
  idNumber     String?
  status       String     @default("IN_CAMPUS")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  host         User       @relation("Host", fields: [hostId], references: [id])
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId, hostId])
  @@map("visitor_logs")
}
