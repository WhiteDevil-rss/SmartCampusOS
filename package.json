{
    "name": "smartcampus-os",
    "private": true,
    "version": "1.0.0",
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "dev:all": "docker compose up -d && pnpm run dev",
        "stop": "docker compose stop",
        "db:init": "docker compose up -d && cd apps/api && npx prisma db push && npx prisma db seed && npx ts-node scripts/seed-firebase.ts",
        "lint": "turbo run lint",
        "test": "turbo run test",
        "type-check": "turbo run type-check",
        "format": "prettier --write \"**/*.{ts,tsx,md}\""
    },
    "devDependencies": {
        "@types/node": "^25.3.2",
        "prettier": "^3.8.1",
        "ts-node": "^10.9.2",
        "turbo": "^2.8.11",
        "typescript": "^5.9.3"
    },
    "packageManager": "pnpm@8.15.5",
    "engines": {
        "node": ">=18"
    }
}